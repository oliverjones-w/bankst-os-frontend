{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "CF_Access_Client_Id", "value": "$CF_CLIENT_ID" },
        { "key": "CF_Access_Client_Secret", "value": "$CF_ACCESS_CLIENT_SECRET" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://100.76.200.30:7842/api/:path*"
    },
    {
      "source": "/((?!js|css|typography|assets|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
